# ============================================================================
# Git Ignore Configuration
# Excludes build artifacts, cache, and system files from version control
# ============================================================================

# Compiled C executable
kmeans
*.o
*.out
*.a
*.so

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv

# Test outputs
c_output.txt
python_output.txt
*.pyc

# Sample/test data (optional - uncomment if needed)
# sample_data.csv

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.sublime-project
.sublime-workspace
.DS_Store

# OS specific
.DS_Store
Thumbs.db
*.ini
*.cfg

# Temporary files
*.tmp
*.bak
*.backup
*~

# Documentation builds
docs/_build/
site/

# Logs
*.log
